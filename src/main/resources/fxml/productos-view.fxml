<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.scene.layout.VBox?>
        <?import javafx.scene.control.TableView?>
        <?import javafx.scene.control.TableColumn?>
        <?import javafx.scene.control.TextField?>
        <?import javafx.scene.control.Button?>
        <?import javafx.scene.control.ComboBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tienda.controller.ProductoController"
      spacing="10" alignment="CENTER">

<TableView fx:id="tabla" prefHeight="200">
    <columns>
        <TableColumn text="Nombre" fx:id="colNombre" prefWidth="150"/>
        <TableColumn text="Precio" fx:id="colPrecio" prefWidth="100"/>
        <TableColumn text="Stock" fx:id="colStock" prefWidth="100"/>
        <TableColumn text="Activo" fx:id="colActivo" prefWidth="80"/>
    </columns>
</TableView>

<TextField fx:id="txtNombre" promptText="Nombre"/>
<TextField fx:id="txtPrecio" promptText="Precio"/>
<TextField fx:id="txtStock" promptText="Stock"/>

<ComboBox fx:id="comboCategoria" promptText="Selecciona categoría"/>
<ComboBox fx:id="comboProveedor" promptText="Selecciona proveedor"/>

<Button text="Guardar" onAction="#guardar"/>
<Button text="Eliminar" onAction="#eliminar"/><Button text="Exportar CSV" onAction="#exportarCSV"/>
    <Button text="Volver al menú" onAction="#volverMenu"/>

</VBox>
